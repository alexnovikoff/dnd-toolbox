# Copy this file to apps/hub/.env and fill in your Anthropic API key.
# The key is read ONLY by the server (api/generate.js + the Vite dev middleware)
# and never reaches the browser bundle. Get one at https://console.anthropic.com/.
ANTHROPIC_API_KEY=

# Optional, personal use only — serve dev /api/generate through your locally
# installed Claude Code CLI (your Claude subscription; no API key, no free-tier
# quota). Lives only in the Vite dev middleware; never deployed.
# LOCAL_CLAUDE=1
# LOCAL_CLAUDE_MODEL=sonnet
# LOCAL_CLAUDE_BIN=claude
