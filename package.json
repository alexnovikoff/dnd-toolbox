{
  "name": "dnd-toolbox",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "D&D Toolbox — a GM tool hub with a shared design system and pluggable modules.",
  "packageManager": "pnpm@9.12.3",
  "engines": {
    "node": ">=18.12.0"
  },
  "scripts": {
    "dev": "pnpm --filter @dnd/hub dev",
    "build": "pnpm -r build",
    "preview": "pnpm --filter @dnd/hub preview",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.4.8",
    "@testing-library/react": "^16.0.1",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^8.57.1",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^4.6.2",
    "jsdom": "^25.0.1",
    "prettier": "^3.3.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vitest": "^2.1.8"
  }
}
